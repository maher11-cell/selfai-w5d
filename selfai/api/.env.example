# SelfAI — secrets for the chat engine.
# Copy this file to .env and fill in the keys you want to use.
# Order of preference: DeepSeek (primary) → OpenRouter → Groq → Gemini → Hugging Face → offline preview.

# === Primary: DeepSeek V4 (deepseek-chat) ===
# Get a key from https://platform.deepseek.com — works in DeepSeek-Chat (V3.x / V4) lineage.
DEEPSEEK_API_KEY=

# === Free fallbacks (any one is enough) ===
# OpenRouter free Llama 3.1 — https://openrouter.ai (sign up free)
OPENROUTER_API_KEY=

# Groq free tier — https://console.groq.com (llama-3.3-70b-versatile)
GROQ_API_KEY=

# Google Gemini free tier — https://aistudio.google.com (gemini-2.0-flash-exp)
GEMINI_API_KEY=

# Hugging Face Inference Router — https://huggingface.co/settings/tokens
HF_TOKEN=
